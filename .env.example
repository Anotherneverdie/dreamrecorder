# 复制为 .env.local 后填入密钥
# cp .env.example .env.local

# SiliconFlow 国内生图 API
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 可用生图模型（你的账号 FLUX 可能已停用，推荐以下之一）：
# Kwai-Kolors/Kolors
# Tongyi-MAI/Z-Image-Turbo
# Qwen/Qwen-Image
# baidu/ERNIE-Image-Turbo
IMAGE_MODEL=Qwen-Image-Edit-2509

# 千禧相机感低分辨率横图（推荐保持）
IMAGE_SIZE=768x512

# 设为 true 时始终使用演示占位图（不调用 API、不扣费）
# IMAGE_DEMO_MODE=true

# 研究员后台 Basic Auth（必须配置，否则 /admin 与后台接口将拒绝访问）
ADMIN_USERNAME=researcher
ADMIN_PASSWORD=change-this-password
