# 复制为 .env.local 后填入密钥
# cp .env.example .env.local


GEMINI_API_KEY=sk-your-key-here
IMAGE_MODEL=gemini-3.1-flash-image-preview

# 千禧相机感低分辨率横图（推荐保持）
IMAGE_SIZE=768x512

# 设为 true 时始终使用演示占位图（不调用 API、不扣费）
# IMAGE_DEMO_MODE=true

# 研究员后台 Basic Auth（必须配置，否则 /admin 与后台接口将拒绝访问）
ADMIN_USERNAME=404notfound
ADMIN_PASSWORD=404notfound
